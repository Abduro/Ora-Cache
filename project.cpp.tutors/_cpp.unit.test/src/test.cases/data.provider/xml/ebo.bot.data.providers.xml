	<urls>
		<url type="currency" uri="https://api.exmo.com/v1/currency/" request="POST/GET">
			<desc>Currencies list;</desc>
			<params/>
		</url>
		<url type="orders" uri="https://api.exmo.com/v1/order_book/" request="POST/GET">
			<desc>The book of current orders on the currency pair;</desc>
			<params>
				<param name="pair" required="yes" type="string">
					<desc>
						One or various currency pairs separated by commas (example: BTC_USD,BTC_EUR);
					</desc>
				</param>
				<param name="limit" required="no" type="integer" max="1000" min="100">
					<desc>
						The number of displayed positions (default: 100, max: 1000);
						But real value range is different from API declaration:
						it is possible to provide limit value that is out of the range;
					</desc>
				</param>
			</params>
		</url>
		<url type="cfg" uri="https://api.exmo.com/v1/pair_settings/" request="POST/GET">
			<desc>Currency pairs settings;</desc>
		</url>
		<url type="ticker" uri="https://api.exmo.com/v1/ticker/" request="POST/GET">
			<desc>Statistics on prices and volume of trades by currency pairs;</desc>
			<params/>
		</url>
		<url type="trades" uri="https://api.exmo.com/v1/trades/" request="POST/GET">
			<desc>List of the deals on currency pairs;</desc>
			<params>
				<param name="pair" required="yes" type="string">
					<desc>
						One or various currency pairs separated by commas (example: BTC_USD,BTC_EUR);
					</desc>
				</param>
			</params>
		</url>
	</urls>
	</provider>
